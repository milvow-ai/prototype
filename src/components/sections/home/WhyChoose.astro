---
/**
 * WhyChoose (home)
 * White bg. Left: heading + accordion of 5 reasons. Right: image with "15+ Years In Solar" badge.
 */

// === IMPORTS ===
import site from '~/content/site.json';
import Section from '~/components/ui/Section.astro';
import Container from '~/components/ui/Container.astro';
import Heading from '~/components/ui/Heading.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';

// === SITE DATA ===
const s: any = site;
const eyebrow = s.whyChoose?.eyebrow || 'WHY SOLAROOFING';
const heading = s.whyChoose?.heading || '';
const items = s.whyChoose?.items || [];
const image = s.whyChoose?.image || '';
const imageBadge = s.whyChoose?.imageBadge || '';

// === CLASS STRINGS ===
const cGrid = 'grid lg:grid-cols-12 gap-10 lg:gap-16 items-start';
const cLeft = 'lg:col-span-7 reveal';
const cAccordion = 'mt-8 space-y-3';
const cItem = 'group bg-bg-cream rounded-2xl border border-edge-light overflow-hidden transition-all duration-300';
const cSummary = 'flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none hover:bg-orange-light/40 transition-colors duration-200';
const cTitle = 'text-base md:text-lg font-display font-bold text-ink';
const cChevron = 'w-5 h-5 text-ink-muted flex-shrink-0 transition-transform duration-300 group-open:rotate-180';
const cAnswer = 'px-6 pb-5 text-sm md:text-base text-ink-muted leading-relaxed';
const cRight = 'lg:col-span-5 relative reveal';
const cImageBox = 'relative rounded-2xl overflow-hidden shadow-card-hover aspect-[4/5] bg-bg-soft';
const cImage = 'w-full h-full object-cover';
const cBadge = 'absolute bottom-4 left-4 right-4 inline-flex items-center justify-center gap-2 px-4 py-3 rounded-full bg-bg-primary/90 backdrop-blur-md text-white text-sm font-bold shadow-xl';
const cBadgeDot = 'w-2 h-2 rounded-full bg-orange animate-pulse-soft';
---

<Section background="light" spacing="lg" ariaLabel="Why Choose Us">
  <Container>
    <div class={cGrid}>
      <div class={cLeft}>
        <Eyebrow variant="plain">{eyebrow}</Eyebrow>
        <Heading level={2} size="xl" align="left" class="mt-4">{heading}</Heading>

        <div class={cAccordion}>
          {items.map((item: any, i: number) => (
            <details class={cItem} open={i === 1}>
              <summary class={cSummary}>
                <span class={cTitle}>{item.title}</span>
                <svg class={cChevron} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class={cAnswer}>{item.description}</div>
            </details>
          ))}
        </div>
      </div>

      <div class={cRight}>
        <div class={cImageBox}>
          {image && (
            <img src={image} alt="Solaroofing installation" width="800" height="1000" class={cImage} loading="lazy" decoding="async" />
          )}
          {imageBadge && (
            <div class={cBadge}>
              <span class={cBadgeDot} aria-hidden="true"></span>
              {imageBadge}
            </div>
          )}
        </div>
      </div>
    </div>
  </Container>

  <style>
    summary::-webkit-details-marker { display: none; }
    summary::marker { display: none; }
  </style>
</Section>
