---
/**
 * Services (home)
 * White bg. Heading center + 2 large service cards with image, features, price, CTA.
 */

// === IMPORTS ===
import site from '~/content/site.json';
import Section from '~/components/ui/Section.astro';
import Container from '~/components/ui/Container.astro';
import Heading from '~/components/ui/Heading.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import Button from '~/components/ui/Button.astro';

// === SITE DATA ===
const s: any = site;
const eyebrow = s.services?.eyebrow || 'SERVICES';
const heading = s.services?.heading || '';
const items = s.services?.items || [];

// === CLASS STRINGS ===
const cHeader = 'text-center max-w-2xl mx-auto mb-12 reveal';
const cGrid = 'grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 reveal-stagger';
const cCard = 'group bg-white rounded-2xl border border-edge-light overflow-hidden flex flex-col md:flex-row hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300';
const cImageWrap = 'relative md:w-2/5 aspect-[4/3] md:aspect-auto bg-bg-cream overflow-hidden flex-shrink-0';
const cImage = 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105';
const cContent = 'flex flex-col p-6 md:p-8 flex-1';
const cName = 'text-xl md:text-2xl font-display font-bold text-ink mb-4 leading-tight';
const cFeatures = 'space-y-2.5 mb-5 flex-grow';
const cFeature = 'flex items-center gap-2 text-sm text-ink-muted';
const cFeatureIcon = 'w-4 h-4 text-orange flex-shrink-0';
const cPrice = 'text-sm font-bold text-ink mb-4';
---

<Section id="services" background="light" spacing="lg" ariaLabel="Services">
  <Container>
    <div class={cHeader}>
      <Eyebrow variant="plain">{eyebrow}</Eyebrow>
      <Heading level={2} size="xl" align="center" class="mt-4">{heading}</Heading>
    </div>

    <div class={cGrid}>
      {items.map((service: any) => (
        <article class={cCard}>
          <div class={cImageWrap}>
            {service.image && (
              <img src={service.image} alt={service.name} width="600" height="450" class={cImage} loading="lazy" decoding="async" />
            )}
          </div>
          <div class={cContent}>
            <h3 class={cName}>{service.name}</h3>
            <ul class={cFeatures}>
              {(service.features || []).map((feat: string) => (
                <li class={cFeature}>
                  <svg class={cFeatureIcon} fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>
            <p class={cPrice}>{service.priceFrom}</p>
            <Button href={service.ctaHref} variant="primary" size="md" withArrow>
              {service.ctaLabel}
            </Button>
          </div>
        </article>
      ))}
    </div>
  </Container>
</Section>
